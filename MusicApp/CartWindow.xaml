<Window x:Class="MusicApp.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Giỏ hàng"
        Height="520"
        Width="860"
        WindowStartupLocation="CenterOwner"
        Background="#2F2D2C"
        FontFamily="Bahnschrift">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Giỏ hàng" FontSize="24" FontWeight="Bold" Foreground="White"/>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="#3A3837" CornerRadius="14" Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Gói dịch vụ" Foreground="#D6D1CF" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ListBox x:Name="lstPackages" Height="320" SelectionMode="Single"/>
                    <Button Content="Thêm vào giỏ" Height="40" Margin="0,12,0,0" Click="BtnAddToCart_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#3A3837" CornerRadius="14" Padding="16">
                <StackPanel>
                    <TextBlock Text="Các gói đã chọn" Foreground="#D6D1CF" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ListView x:Name="lvCart" Height="280" Margin="0,0,0,10">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Gói" Width="220" DisplayMemberBinding="{Binding Package.Name}"/>
                                <GridViewColumn Header="SL" Width="50" DisplayMemberBinding="{Binding Quantity}"/>
                                <GridViewColumn Header="Thành tiền" Width="120" DisplayMemberBinding="{Binding LineTotal}"/>
                                <GridViewColumn Header="" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Xóa" Click="BtnRemoveItem_Click" Height="28"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <TextBlock x:Name="txtTotal" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Button Content="Thanh toán" Height="40" Click="BtnCheckout_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Đóng" Width="110" Height="40" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>

