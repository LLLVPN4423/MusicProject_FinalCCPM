<Window x:Class="MusicApp.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh toán - Nâng cấp Premium"
        Height="420"
        Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#2F2D2C"
        FontFamily="Bahnschrift">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Thanh toán - Nâng cấp Premium"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="White"/>

        <Border Grid.Row="1" Margin="0,18,0,18" Background="#3A3837" CornerRadius="14" Padding="16">
            <StackPanel>
                <TextBlock x:Name="txtSummary" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,14"/>

                <TextBlock Text="Phương thức thanh toán" Foreground="#D6D1CF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox x:Name="cmbMethod" Height="36">
                    <ComboBoxItem Content="Ví điện tử"/>
                    <ComboBoxItem Content="Thẻ ngân hàng"/>
                    <ComboBoxItem Content="Chuyển khoản"/>
                </ComboBox>

                <TextBlock x:Name="txtError" Foreground="#FFB4B4" Margin="0,12,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Thanh toán" Width="140" Height="40" Click="BtnPay_Click" Margin="0,0,10,0"/>
            <Button Content="Đóng" Width="110" Height="40" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>

