<Window x:Class="MusicApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cài đặt"
        Height="520"
        Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#2F2D2C"
        FontFamily="Bahnschrift">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Cài đặt"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="White"/>

        <Border Grid.Row="1" Margin="0,18,0,18" Background="#3A3837" CornerRadius="14" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Tài khoản" Foreground="#D6D1CF" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtAccountStatus" Text="Chưa đăng nhập" Foreground="White" Margin="0,0,0,14"/>

                    <Button x:Name="btnLogin" Content="Đăng nhập" Height="40" Click="BtnLogin_Click" Margin="0,0,0,10"/>
                    <Button x:Name="btnRegister" Content="Đăng ký" Height="40" Click="BtnRegister_Click" Margin="0,0,0,10"/>
                    <Button x:Name="btnLogout" Content="Đăng xuất" Height="40" Click="BtnLogout_Click"/>

                    <Border Background="#2F2D2C" CornerRadius="12" Padding="14" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Hồ sơ người dùng (Passport/Profile)"
                                       Foreground="#D6D1CF"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Người dùng:" Foreground="#D6D1CF" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtProfileUsername" Text="Chưa đăng nhập" Foreground="White" Margin="0,0,0,10"/>

                            <TextBlock x:Name="txtProfilePremium" Foreground="White" Margin="0,0,0,10" TextWrapping="Wrap"/>
                            <TextBlock x:Name="txtProfileFavoritesCount" Foreground="White" Margin="0,0,0,10"/>

                            <TextBlock Text="Sở thích âm nhạc (top ca sĩ)" Foreground="#D6D1CF" FontWeight="SemiBold" Margin="0,6,0,8"/>
                            <TextBlock x:Name="txtProfileTopArtists" Foreground="White" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="Premium &amp; Giỏ hàng" Foreground="#D6D1CF" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Button Content="Giỏ hàng" Height="40" Click="BtnCart_Click" Margin="0,0,0,10"/>
                    <Button Content="Nâng cấp Premium (Thanh toán)" Height="40" Click="BtnPayment_Click" Margin="0,0,0,18"/>

                    <TextBlock Text="Dữ liệu" Foreground="#D6D1CF" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Button Content="Xóa lịch sử nghe" Height="40" Click="BtnClearHistory_Click" Margin="0,0,0,10"/>
                    <Button Content="Xóa danh sách yêu thích" Height="40" Click="BtnClearFavorites_Click"/>

                    <Border Background="#2F2D2C" CornerRadius="12" Padding="14" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Cài đặt Hệ thống" Foreground="#D6D1CF" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <TextBlock Text="Âm lượng mặc định" Foreground="#D6D1CF" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Slider x:Name="sldDefaultVolume"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="0.5"
                                    Height="28"
                                    TickFrequency="0.01"
                                    ValueChanged="SldDefaultVolume_ValueChanged"/>
                            <TextBlock x:Name="lblDefaultVolume" Foreground="White" Text="50%" Margin="0,0,0,12"/>

                            <CheckBox x:Name="chkEnableShortcuts"
                                      Content="Bật phím tắt"
                                      Foreground="White"
                                      Margin="0,0,0,6"
                                      Checked="ChkEnableShortcuts_Checked"
                                      Unchecked="ChkEnableShortcuts_Checked"/>
                            <TextBlock Foreground="#D6D1CF" TextWrapping="Wrap" FontSize="12"
                                       Text="Phím tắt: Space phát/dừng, ←/→ trước/sau, M tắt/mở tiếng"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Đóng" Width="110" Height="40" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>

